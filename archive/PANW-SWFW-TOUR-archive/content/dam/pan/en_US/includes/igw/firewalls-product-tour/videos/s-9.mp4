        .btn-primary:not(:disabled):not(.disabled).active,.btn-primary:not(:disabled):not(.disabled):active,.show>.btn-primary.dropdown-toggle{background-color:#f94414;border-color:#f94414;color:#141414}
        .panClean .prismaNav2021Component .prisma-2021-nav-main .nav-left .mega-dropdown-menu .col-tiles .tile .btn.btn-dark:hover{background-color:transparent!important;border-color:transparent!important}
        .panClean .prismaNav2021Component .prisma-2021-nav-main .btn.btn-primary.prisma-btn:hover{background-color:#0fd6ff!important;border-color:#0fd6ff!important}
        .panClean .prismaNav2021Component .prisma-2021-nav-main .nav-right>li.cta .btn.prisma-btn:focus{box-shadow:0 0 0 3px #00c0e8!important}
        .main-404-content{padding:5.5rem 0 3.5rem 0;border-bottom:1px solid #d8d8d8}
        .cleanDynamicFooter{margin-top:0}
        .main-404-content p{color:#727272;font-family:TT Hoves,Arial,"Helvetica Neue",Helvetica,sans-serif;font-size:1rem;line-height:150%}
        .main-404-content h1{font-family:TT Hoves,Arial,"Helvetica Neue",Helvetica,sans-serif;font-size:3rem;line-height:120%;font-style:italic;font-weight:600}
        .main-404-content hr{margin-top:22px;margin-bottom:22px;border:0;border-top:1px solid #f1f1f1}
        @media(max-width:767px){
            .cleanDynamicFooter{overflow:unset}
            .cleanDynamicFooter .dropdown .dropdown-menu{width:315px;top:-15px!important;right:0!important;transform:translateY(-100%)!important;left:auto!important}
        }
        @media(min-width:768px){
            .main-404-content h1{font-size:calc(2rem + (72 - 32) *((100vw - 768px) /(1920 - 768)))}
            .main-404-content p{font-size:1.25rem;line-height:160%}
        }

        @media(min-width:1200px){
            .panClean .nav2021Component .pan-2021-nav-toolbar .toolbar-nav > li .dropdown > .dropdown-menu{min-width:220px;margin-top: 0px;}
        }
    </style>
