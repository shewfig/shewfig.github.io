// window.addEventListener('load', syncMegaMenuTitles);
// window.addEventListener('resize', syncMegaMenuTitles);



function syncMegaMenuTitles() {
  // Only run if the screen width is above 1200px
  if (window.innerWidth <= 1200) {
    // Clean up: Reset heights if the user shrinks the window
    const allTitles = document.querySelectorAll('.mega-dropdown-menu .title');
    allTitles.forEach(t => t.style.height = 'auto');
    return; 
  }

  const menus = document.querySelectorAll('.mega-dropdown-menu');

  menus.forEach(menu => {
    const titles = menu.querySelectorAll('.title');
    let max = 0;

    // Reset to measure natural height
    titles.forEach(t => t.style.height = 'auto');

    // Measure tallest title
    titles.forEach(t => {
      const h = t.offsetHeight;
      if (h > max) max = h;
    });

    // Apply the height
    if (max > 0) {
      titles.forEach(t => {
        t.style.setProperty('height', max + 'px', 'important');
      });
    }
  });
}

// Event Listeners
window.addEventListener('load', syncMegaMenuTitles);
window.addEventListener('resize', syncMegaMenuTitles);
    </script>
